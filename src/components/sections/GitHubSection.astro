---
import GitHubGlobe from '../canvas/GitHubGlobe';
---

<section id="github-globe" class="relative w-full border-t border-white/10 bg-dark-900">
  <div class="absolute inset-0 z-0 opacity-20 pointer-events-none" style="background-image: radial-gradient(circle at center, var(--color-primary), transparent 70%);"></div>
  
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 py-20 flex flex-col items-center">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-black font-outfit uppercase tracking-tighter text-white drop-shadow-md">
        Live <span class="text-neon-cyan">Global</span> Commits
      </h2>
      <p class="text-slate-400 font-mono text-sm max-w-2xl mx-auto mt-4">
        Simulating a real-time stream of 1,000,000 parallel events computed entirely on the GPU via Three Shading Language (TSL).
      </p>
    </div>
  </div>

  <!-- Isolated WebGPU Canvas Container -->
  <div class="w-full relative z-10 pointer-events-none">
    <GitHubGlobe client:only="react" />
  </div>

</section>
