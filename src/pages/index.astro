---
import Layout from '../layouts/Layout.astro';
import { PORTFOLIO_CONFIG } from '../config/portfolio.config';
import OrbitalCanvas from '../components/canvas/OrbitalCanvas';
import TechForceGraph from '../components/canvas/TechForceGraph';
import AIAvatar from '../components/ui/AIAvatar';
import HackerTerminal from '../components/terminal/HackerTerminal';
import KeyboardManager from '../components/KeyboardManager';
import CinematicLoader from '../components/ui/CinematicLoader';
import SettingsMenu from '../components/ui/SettingsMenu';
import DownloadResumeButton from '../components/ui/DownloadResumeButton';

const activeThemeId = PORTFOLIO_CONFIG.themeEngine[0].id;
const activeTheme = PORTFOLIO_CONFIG.themeEngine[0].tokens;

let btnBgInit, btnTextInit;
if (activeThemeId === 'minimalist') {
  btnBgInit = '#e2e8f0'; 
  btnTextInit = '#0f172a';
} else if (activeThemeId === 'matrix') {
  btnBgInit = '#ffffff';
  btnTextInit = '#000000';
} else {
  btnBgInit = activeTheme.accent;
  btnTextInit = '#ffffff';
}
---

<Layout title={PORTFOLIO_CONFIG.globalMetadata.siteName}>
  <!-- Theme Injection -->
  <style define:vars={{
    bgPrimary: activeTheme.background,
    primary: activeTheme.primary,
    secondary: activeTheme.surface,
    accent: activeTheme.accent,
    btnBgInit,
    btnTextInit
  }}>
    :root {
      --bg-primary: var(--bgPrimary);
      --color-primary: var(--primary);
      --color-secondary: var(--secondary);
      --color-accent: var(--accent);
      --btn-bg: var(--btnBgInit);
      --btn-text: var(--btnTextInit);
    }
  </style>

  <!-- Background Mesh -->
  <div class="bg-mesh pointer-events-none">
    <div class="mesh-blob-1 animate-blob"></div>
    <div class="mesh-blob-2 animate-blob-reverse"></div>
    <div class="mesh-blob-3 animate-blob"></div>
  </div>

  <!-- Phase 4 Loader -->
  <CinematicLoader client:load />
  <!-- Phase 3 UI Overlays -->
  <KeyboardManager client:load />
  <HackerTerminal client:only="react" />
  <AIAvatar client:load />

  <!-- WebGL Background and Graph -->
  <OrbitalCanvas client:only="react" />
  <TechForceGraph client:only="react" />

  <!-- Sticky Navigation -->
  <nav class="fixed w-full z-50 top-0 transition-all duration-300 glass border-b-0" id="navbar">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between h-20">
              <div class="flex-shrink-0 font-display font-black text-2xl tracking-tighter">
                  <span class="text-brand-400">&lt;</span>vikas<span class="text-brand-600">/&gt;</span>
              </div>
              <div class="hidden md:flex items-center">
                  <div class="ml-10 flex items-center space-x-8 font-medium">
                      <a href="#about" class="text-slate-300 hover:text-white transition-colors text-sm uppercase tracking-wider relative group">
                          About
                          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-400 transition-all group-hover:w-full"></span>
                      </a>
                      <a href="#experience" class="text-slate-300 hover:text-white transition-colors text-sm uppercase tracking-wider relative group">
                          Experience
                          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-500 transition-all group-hover:w-full"></span>
                      </a>
                      <a href="#projects" class="text-slate-300 hover:text-white transition-colors text-sm uppercase tracking-wider relative group">
                          Projects
                          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-600 transition-all group-hover:w-full"></span>
                      </a>
                      <a href="#contact" class="relative inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold text-btn-text transition-all duration-200 bg-btn-bg rounded-full hover:brightness-110 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 hover:shadow-[0_0_20px_var(--color-brand-500)] overflow-hidden group">
                          <span class="absolute inset-0 w-full h-full -mt-1 rounded-lg opacity-30 bg-gradient-to-b from-transparent via-transparent to-black"></span>
                          <span class="relative">Let's Talk</span>
                      </a>
                  </div>
                  <SettingsMenu client:load />
              </div>
          </div>
      </div>
  </nav>

  <!-- Hero Section -->
  <header class="relative pt-32 pb-20 min-h-screen flex items-center lg:pt-48 lg:pb-32 overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full flex flex-col lg:flex-row items-center justify-between gap-12">
          <div class="lg:w-3/5 text-center lg:text-left z-10 reveal">
              <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass border-brand-500/30 text-brand-400 text-sm font-semibold tracking-wide uppercase mb-6 shadow-[0_0_15px_rgba(56,189,248,0.2)]">
                  <span class="relative flex h-3 w-3">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-3 w-3 bg-brand-500"></span>
                  </span>
                  Available for new opportunities
              </div>
              <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-black tracking-tight mb-6 leading-[1.1]">
                  Crafting <br>
                  <span class="text-gradient">Digital Reality.</span>
              </h1>
              <p class="mt-6 text-lg md:text-xl text-slate-100 drop-shadow-md max-w-2xl mb-10 leading-relaxed font-medium mx-auto lg:mx-0">
                  {PORTFOLIO_CONFIG.personalProfile.titles[0]} specializing in transforming complex problems into elegant, scalable, and high-performance web and AI solutions.
              </p>
              <div class="flex flex-col sm:flex-row gap-5 justify-center lg:justify-start">
                  <a href="#projects" class="group relative px-8 py-4 font-bold text-dark-900 bg-white rounded-full overflow-hidden transition-all hover:scale-105">
                      <div class="absolute inset-0 w-full h-full transition-all duration-300 ease-out transform translate-x-full bg-brand-400 group-hover:translate-x-0"></div>
                      <span class="relative group-hover:text-white flex items-center justify-center gap-2">
                          Explore Work <i class="fa-solid fa-arrow-right -rotate-45 group-hover:rotate-0 transition-transform"></i>
                      </span>
                  </a>
                  <a href={PORTFOLIO_CONFIG.personalProfile.contact.github} target="_blank" class="px-8 py-4 font-bold text-white glass rounded-full hover:bg-white/10 transition-all hover:border-brand-400/50 flex items-center justify-center gap-2">
                      <i class="fa-brands fa-github text-xl"></i> View GitHub
                  </a>
                  <div class="flex items-center justify-center">
                      <DownloadResumeButton client:only="react" />
                  </div>
              </div>
          </div>

          <!-- 3D Interactive Code Card -->
          <div class="lg:w-2/5 mt-16 lg:mt-0 hidden md:block reveal" style="transition-delay: 200ms;">
              <div class="relative w-full max-w-md mx-auto animate-float">
                  <div class="absolute inset-0 bg-gradient-to-tr from-brand-400 to-brand-600 rounded-2xl blur-2xl opacity-20"></div>
                  <div class="relative glass-card rounded-2xl p-6 shadow-2xl">
                      <div class="flex gap-2 mb-6 border-b border-white/10 pb-4">
                          <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
                          <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
                          <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
                      </div>
                      <div class="text-sm font-mono text-slate-300 space-y-2" id="code-container">
                          <!-- Populated by JS -->
                      </div>
                  </div>
              </div>
          </div>
      </div>

      <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 flex flex-col items-center gap-2 opacity-50 hover:opacity-100 transition-opacity animate-bounce">
          <span class="text-xs uppercase tracking-widest text-slate-400">Scroll</span>
          <i class="fa-solid fa-chevron-down text-brand-400"></i>
      </div>
  </header>

  <!-- Expertise Section -->
  <section id="about" class="py-24 relative z-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-16 reveal">
              <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">Engineering <span class="text-brand-500">Excellence</span></h2>
              <div class="h-1 w-20 bg-brand-500 mx-auto rounded-full mb-6"></div>
              <p class="text-slate-400 max-w-2xl mx-auto">Mastering the entire stack with a focus on architecture, performance, and clean code.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              <div class="glass-card p-8 rounded-2xl reveal group">
                  <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-brand-400/20 to-brand-600/20 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                      <i class="fa-solid fa-layer-group text-brand-400 text-2xl"></i>
                  </div>
                  <h3 class="font-display text-2xl font-bold mb-3">AI & Swarm Architecture</h3>
                  <p class="text-slate-400 text-sm leading-relaxed mb-6">Building state-of-the-art multi-agent swarms and RAG capabilities with Python and Java 21.</p>
              </div>

              <div class="glass-card p-8 rounded-2xl reveal group" style="transition-delay: 100ms;">
                  <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-emerald-400/20 to-emerald-600/20 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                      <i class="fa-solid fa-server text-emerald-400 text-2xl"></i>
                  </div>
                  <h3 class="font-display text-2xl font-bold mb-3">Low-Latency Systems</h3>
                  <p class="text-slate-400 text-sm leading-relaxed mb-6">Designing ultra-low-latency zero-copy execution engines for HFT using C++20 and Rust.</p>
              </div>

              <div class="glass-card p-8 rounded-2xl reveal group" style="transition-delay: 200ms;">
                  <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-purple-400/20 to-purple-600/20 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                      <i class="fa-solid fa-cloud text-purple-400 text-2xl"></i>
                  </div>
                  <h3 class="font-display text-2xl font-bold mb-3">Web3 & Cloud</h3>
                  <p class="text-slate-400 text-sm leading-relaxed mb-6">Automating deployments and building intent-centric Smart Accounts with zkML.</p>
              </div>
          </div>
      </div>
  </section>

  <!-- Experience Section -->
  <section id="experience" class="py-24 relative z-10 bg-dark-900/40 border-t border-white/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-16 reveal">
              <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">Certifications & <span class="text-brand-500">Experience</span></h2>
              <div class="h-1 w-20 bg-brand-500 mx-auto rounded-full mb-6"></div>
              <p class="text-slate-400 max-w-2xl mx-auto">A relentless pursuit of knowledge with 37+ verified certifications.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {PORTFOLIO_CONFIG.certificationGraph.map((cert) => (
                  <div class="glass-card p-6 rounded-xl reveal hover:-translate-y-1 transition-transform border border-white/5 hover:border-brand-500/30 group">
                      <div class="text-brand-400 font-mono text-xs mb-2">{cert.date}</div>
                      <h3 class="font-display font-bold text-lg mb-1 leading-tight group-hover:text-white transition-colors">{cert.title}</h3>
                      <p class="text-slate-400 text-sm mb-4">{cert.issuer}</p>
                      <div class="flex flex-wrap gap-2 mt-auto">
                          {cert.tags.map(tag => (
                              <span class="text-xs px-2 py-1 bg-white/5 rounded-full text-slate-300">{tag}</span>
                          ))}
                      </div>
                  </div>
              ))}
          </div>
      </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-24 relative z-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col md:flex-row justify-between items-end mb-16 reveal">
              <div>
                  <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">Selected <span class="text-brand-500">Works</span></h2>
                  <div class="h-1 w-20 bg-brand-500 rounded-full mb-2"></div>
              </div>
              <a href={PORTFOLIO_CONFIG.personalProfile.contact.github} target="_blank" class="text-brand-400 hover:text-white transition-colors mt-4 md:mt-0 font-medium flex items-center gap-2">
                  View full archive <i class="fa-solid fa-arrow-right"></i>
              </a>
          </div>

          <div class="space-y-24">
              {PORTFOLIO_CONFIG.projectMatrix.map((proj, index) => (
                  <div class={`flex flex-col ${index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-12 items-center reveal`}>
                      <div class="lg:w-7/12 relative group w-full">
                          <div class="absolute -inset-1 bg-gradient-to-r from-brand-500 to-purple-600 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
                          <div class="relative rounded-2xl overflow-hidden aspect-video border border-white/10 bg-dark-800 flex items-center justify-center">
                              {proj.media && proj.media.fallback && !proj.media.fallback.includes('jpg') ? (
                                  <img src={proj.media.fallback} alt={proj.title} class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-500" loading="lazy" />
                              ) : (
                                  <span class="text-brand-400 opacity-50 text-2xl font-display font-bold">&lt;{proj.title} /&gt;</span>
                              )}
                              <div class="absolute inset-0 bg-dark-900/40 group-hover:bg-transparent transition-colors duration-500"></div>
                          </div>
                      </div>
                      <div class={`lg:w-5/12 ${index % 2 === 0 ? 'lg:pl-8' : 'lg:pr-8 lg:items-end lg:text-right'} flex flex-col justify-center`}>
                          <div class="text-brand-400 font-mono text-sm mb-3 font-semibold">0{index + 1} / {proj.status}</div>
                          <h3 class="font-display text-3xl font-bold mb-6">{proj.title}</h3>
                          <div class="glass p-6 rounded-xl mb-6 shadow-xl relative z-10">
                              <p class="text-slate-300 text-sm leading-relaxed">{proj.architectureSummary}</p>
                          </div>
                          <ul class={`flex flex-wrap ${index % 2 === 0 ? '' : 'lg:justify-end'} gap-3 mb-8 font-mono text-xs text-slate-400`}>
                              {proj.techStack.map(tech => (
                                  <li class="glass px-3 py-1 rounded-full">{tech}</li>
                              ))}
                          </ul>
                          <div class="flex gap-4">
                              <a href={PORTFOLIO_CONFIG.personalProfile.contact.github} class="hover:text-brand-400 transition-colors font-medium"><i class="fa-brands fa-github mr-2"></i>Source</a>
                          </div>
                      </div>
                  </div>
              ))}
          </div>
      </div>
  </section>

  <!-- Call to Action -->
  <section id="contact" class="py-32 relative z-10 border-t border-t-[var(--glass-border)] mt-10">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-brand-900/20 -z-10"></div>
      <div class="max-w-4xl mx-auto px-4 text-center reveal">
          <h2 class="font-display text-5xl md:text-7xl font-black mb-8 tracking-tight">Let's <span class="text-gradient">Collaborate</span></h2>
          <p class="text-xl text-slate-400 mb-12 max-w-2xl mx-auto font-light leading-relaxed">
              I'm actively looking for new opportunities. If you have an exciting project or want to build something incredible, my inbox is always open.
          </p>
          <a href={`mailto:${PORTFOLIO_CONFIG.personalProfile.contact.email}`} class="relative inline-flex items-center justify-center px-10 py-5 text-lg font-bold text-btn-text transition-all duration-200 bg-btn-bg rounded-full hover:brightness-110 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 hover:scale-105 hover:shadow-[0_0_40px_var(--color-brand-500)] group">
              <i class="fa-regular fa-envelope mr-3 text-xl group-hover:animate-bounce"></i> Say Hello
          </a>

          <div class="mt-20 flex justify-center gap-8">
              <a href={PORTFOLIO_CONFIG.personalProfile.contact.github} target="_blank" class="w-12 h-12 rounded-full glass flex items-center justify-center text-slate-400 hover:text-white hover:border-brand-400 hover:bg-brand-500/20 transition-all hover:-translate-y-1">
                  <i class="fa-brands fa-github text-xl"></i>
              </a>
              <a href={PORTFOLIO_CONFIG.personalProfile.contact.linkedin} target="_blank" class="w-12 h-12 rounded-full glass flex items-center justify-center text-slate-400 hover:text-white hover:border-brand-400 hover:bg-brand-500/20 transition-all hover:-translate-y-1">
                  <i class="fa-brands fa-linkedin-in text-xl"></i>
              </a>
          </div>
      </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 text-center text-text-muted text-sm font-medium border-t border-t-[var(--glass-border)] relative z-10 glass">
      <p>&copy; 2026 {PORTFOLIO_CONFIG.personalProfile.name}. Designed & Engineered with precision.</p>
  </footer>
</Layout>

<script>
  import { audioEngine } from '../utils/audioEngine';

  // Global Audio Hooks
  document.addEventListener('mouseover', (e) => {
    const target = e.target as HTMLElement;
    if (target.tagName === 'A' || target.tagName === 'BUTTON' || target.closest('a') || target.closest('button')) {
      audioEngine.playHover();
    }
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.tagName === 'A' || target.tagName === 'BUTTON' || target.closest('a') || target.closest('button')) {
      audioEngine.playClick();
    }
  });

  // Scroll Reveal Animation
  const revealElements = document.querySelectorAll('.reveal');

  const revealCallback = (entries: any, observer: any) => {
      entries.forEach((entry: any) => {
          if (entry.isIntersecting) {
              entry.target.classList.add('active');
              observer.unobserve(entry.target);
          }
      });
  };

  const revealOptions = {
      threshold: 0.15,
      rootMargin: "0px 0px -50px 0px"
  };

  const revealObserver = new IntersectionObserver(revealCallback, revealOptions);

  revealElements.forEach(el => revealObserver.observe(el));

  // Code typing animation
  const codeLines = [
      "<span class='text-brand-400'>const</span> <span class='text-purple-400'>developer</span> <span class='text-brand-400'>=</span> {",
      "&nbsp;&nbsp;<span class='text-slate-300'>name:</span> <span class='text-emerald-400'>'Vikas Tiwari'</span>,",
      "&nbsp;&nbsp;<span class='text-slate-300'>role:</span> <span class='text-emerald-400'>'Senior Full Stack Engineer'</span>,",
      "&nbsp;&nbsp;<span class='text-slate-300'>skills:</span> [<span class='text-emerald-400'>'React'</span>, <span class='text-emerald-400'>'Rust'</span>, <span class='text-emerald-400'>'Python'</span>],",
      "&nbsp;&nbsp;<span class='text-slate-300'>status:</span> <span class='text-emerald-400'>'Ready to build'</span>",
      "};",
      "",
      "<span class='text-slate-500'>// Initializing sequence...</span>",
      "<span class='text-purple-400'>developer</span>.<span class='text-brand-400'>buildAwesome</span>();"
  ];

  const codeContainer = document.getElementById('code-container');
  let currentLine = 0;

  function typeCode() {
      if (currentLine < codeLines.length && codeContainer) {
          const p = document.createElement('p');
          p.innerHTML = codeLines[currentLine];
          if (codeLines[currentLine] !== "") {
              p.classList.add('code-line');
              p.style.animationDuration = Math.max(0.5, codeLines[currentLine].length * 0.05) + 's';
          }
          codeContainer.appendChild(p);

          const cursor = document.createElement('span');
          cursor.className = 'cursor';
          p.appendChild(cursor);

          if (currentLine > 0 && codeContainer.children[currentLine - 1].querySelector('.cursor')) {
              codeContainer.children[currentLine - 1].querySelector('.cursor')?.remove();
          }

          currentLine++;
          setTimeout(typeCode, 800);
      }
  }

  setTimeout(typeCode, 1000);

  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
      if (window.scrollY > 50 && navbar) {
          navbar.classList.add('bg-dark-900/80', 'backdrop-blur-lg', 'border-b', 'border-white/10');
          navbar.classList.remove('glass', 'border-b-0');
      } else if (navbar) {
          navbar.classList.remove('bg-dark-900/80', 'backdrop-blur-lg', 'border-b', 'border-white/10');
          navbar.classList.add('glass', 'border-b-0');
      }
  });
</script>
