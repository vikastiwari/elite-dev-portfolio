---
import Layout from '../layouts/Layout.astro';
import { PORTFOLIO_CONFIG } from '../config/portfolio.config';
import OrbitalCanvas from '../components/canvas/OrbitalCanvas';
import TechForceGraph from '../components/canvas/TechForceGraph';
import AIAvatar from '../components/ui/AIAvatar';
import HackerTerminal from '../components/terminal/HackerTerminal';
import KeyboardManager from '../components/KeyboardManager';
import CinematicLoader from '../components/ui/CinematicLoader';
import { ZKVault } from '../components/ui/ZKVault';

import GlobalScripts from '../components/GlobalScripts.astro';
import Navigation from '../components/sections/Navigation.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ExpertiseSection from '../components/sections/ExpertiseSection.astro';
import ExperienceSection from '../components/sections/ExperienceSection.astro';
import ProjectsSection from '../components/sections/ProjectsSection.astro';
import GitHubSection from '../components/sections/GitHubSection.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import Footer from '../components/sections/Footer.astro';

const activeThemeId = PORTFOLIO_CONFIG.themeEngine[0].id;
const activeTheme = PORTFOLIO_CONFIG.themeEngine[0].tokens;

let btnBgInit, btnTextInit;
if (activeThemeId === 'minimalist') {
  btnBgInit = '#e2e8f0'; 
  btnTextInit = '#0f172a';
} else if (activeThemeId === 'matrix') {
  btnBgInit = '#ffffff';
  btnTextInit = '#000000';
} else {
  btnBgInit = activeTheme.accent;
  btnTextInit = '#ffffff';
}
---

<Layout title={PORTFOLIO_CONFIG.globalMetadata.siteName}>
  <!-- Theme Injection -->
  <style define:vars={{
    bgPrimary: activeTheme.background,
    primary: activeTheme.primary,
    secondary: activeTheme.surface,
    accent: activeTheme.accent,
    btnBgInit,
    btnTextInit
  }}>
    :root {
      --bg-primary: var(--bgPrimary);
      --color-primary: var(--primary);
      --color-secondary: var(--secondary);
      --color-accent: var(--accent);
      --btn-bg: var(--btnBgInit);
      --btn-text: var(--btnTextInit);
    }
  </style>

  <!-- Background Mesh -->
  <div class="bg-mesh pointer-events-none">
    <div class="mesh-blob-1 animate-blob"></div>
    <div class="mesh-blob-2 animate-blob-reverse"></div>
    <div class="mesh-blob-3 animate-blob"></div>
  </div>

  <!-- Phase 4 Loader -->
  <CinematicLoader client:load />
  
  <!-- Phase 3 UI Overlays -->
  <KeyboardManager client:load />
  <HackerTerminal client:only="react" />
  <AIAvatar client:load />

  <!-- WebGL Background and Graph -->
  <OrbitalCanvas client:only="react" />
  <TechForceGraph client:only="react" />

  <!-- Modular Sections -->
  <Navigation />
  <HeroSection />
  <ExpertiseSection />
  <ExperienceSection />
  <GitHubSection />
  <ProjectsSection />
  <ContactSection />
  <ZKVault client:only="react" />
  <Footer />

  <!-- Global Scripts (Audio, Scroll Reveal) -->
  <GlobalScripts />
</Layout>
