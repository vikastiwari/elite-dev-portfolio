---
import Layout from '../layouts/Layout.astro';
import { PORTFOLIO_CONFIG } from '../config/portfolio.config';

const { personalProfile, projectMatrix, certificationGraph, skills } = PORTFOLIO_CONFIG;
---

<Layout title={`${personalProfile.name} | ATS Resume`}>
  <main class="min-h-screen bg-slate-900 text-slate-200 font-sans p-8 md:p-16 max-w-5xl mx-auto selection:bg-cyan-500 selection:text-white">
    
    <header class="border-b border-slate-700 pb-8 mb-12">
      <h1 class="text-5xl font-bold text-white tracking-tight mb-4">{personalProfile.name}</h1>
      <h2 class="text-2xl text-cyan-400 font-mono mb-4">{personalProfile.titles.join(' | ')}</h2>
      
      <div class="flex gap-6 text-sm text-slate-400">
        <a href={personalProfile.contact.github} class="hover:text-cyan-300 transition-colors">GitHub</a>
        <a href={personalProfile.contact.linkedin} class="hover:text-cyan-300 transition-colors">LinkedIn</a>
        <a href={`mailto:${personalProfile.contact.email}`} class="hover:text-cyan-300 transition-colors">Email</a>
        <a href="/" class="hover:text-pink-400 transition-colors font-bold ml-auto">← Return to WebGL Portal</a>
      </div>
    </header>

    <section class="mb-16">
      <h3 class="text-3xl font-bold text-white mb-6 border-l-4 border-cyan-500 pl-4">Core Skills</h3>
      <div class="flex flex-wrap gap-3">
        {skills.map(skill => (
          <span class="px-3 py-1 bg-slate-800 border border-slate-700 rounded-md text-sm text-cyan-100 shadow-sm">
            {skill.name}
          </span>
        ))}
      </div>
    </section>

    <section class="mb-16">
      <h3 class="text-3xl font-bold text-white mb-8 border-l-4 border-cyan-500 pl-4">Engineering Projects</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {projectMatrix.map(project => (
          <article class="bg-slate-800/50 border border-slate-700 p-6 rounded-xl shadow-lg backdrop-blur-sm hover:border-cyan-500/50 transition-colors">
            <header class="flex justify-between items-start mb-4">
              <h4 class="text-xl font-bold text-white">{project.title}</h4>
              <span class={`text-xs px-2 py-1 rounded-full ${project.status === 'Production' ? 'bg-green-500/20 text-green-300 border border-green-500/30' : 'bg-amber-500/20 text-amber-300 border border-amber-500/30'}`}>
                {project.status}
              </span>
            </header>
            <p class="text-slate-300 text-sm mb-6 leading-relaxed">
              {project.architectureSummary}
            </p>
            <div class="flex flex-wrap gap-2 mt-auto">
              {project.techStack.map(tech => (
                <span class="text-xs bg-slate-900 px-2 py-1 rounded text-slate-400">
                  {tech}
                </span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section>
      <h3 class="text-3xl font-bold text-white mb-8 border-l-4 border-cyan-500 pl-4">Elite Certifications</h3>
      <div class="space-y-4">
        {certificationGraph.map(cert => (
          <div class="flex flex-col md:flex-row justify-between items-baseline border-b border-slate-800 pb-4">
            <div>
              <h4 class="text-lg font-medium text-white">{cert.title}</h4>
              <p class="text-slate-400 text-sm">{cert.issuer}</p>
            </div>
            <time class="text-slate-500 text-sm font-mono mt-2 md:mt-0">{cert.date}</time>
          </div>
        ))}
      </div>
    </section>

  </main>
</Layout>
